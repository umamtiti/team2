<launch>
  <arg name="robot_name" default="sgr532"/>
  <arg name="robot_model" default="$(arg robot_name)"/>
  <arg name="serialname" default="/dev/sagittarius"/>
  <arg name="video_dev" default="/dev/usb_cam"/>
  <arg name="image_width" default="640"/>
  <arg name="image_height" default="480"/>
  <arg name="pixel_format" default="yuyv"/>
  <arg name="framerate" default="30"/>
  <arg name="camera_frame_id" default="usb_cam"/>
  <arg name="io_method" default="mmap"/>
  <arg name="use_camera" default="true"/>
  <arg name="use_rviz" default="false"/>
  <arg name="image_topic" default="/usb_cam/image_raw"/>
  <arg name="vision_config" default="$(find sagittarius_object_color_detector)/config/vision_config.yaml"/>
  <arg name="service_name" default="openclaw/run_command"/>
  <arg name="find_timeout" default="60.0"/>
  <arg name="publish_debug_images" default="false"/>

  <include file="$(find sagittarius_moveit)/launch/demo_true.launch">
    <arg name="robot_name" value="$(arg robot_name)"/>
    <arg name="robot_model" value="$(arg robot_model)"/>
    <arg name="serialname" value="$(arg serialname)"/>
    <arg name="use_rviz" value="$(arg use_rviz)"/>
    <arg name="use_default_rviz" value="false"/>
  </include>

  <node pkg="sagittarius_object_color_detector"
        type="sgr_ctrl.py"
        name="sgr_ctrl_node"
        ns="$(arg robot_name)"
        output="screen"/>

  <include if="$(arg use_camera)" file="$(find sagittarius_object_color_detector)/launch/usb_cam.launch">
    <arg name="video_dev" value="$(arg video_dev)"/>
    <arg name="image_width" value="$(arg image_width)"/>
    <arg name="image_height" value="$(arg image_height)"/>
    <arg name="pixel_format" value="$(arg pixel_format)"/>
    <arg name="framerate" value="$(arg framerate)"/>
    <arg name="camera_frame_id" value="$(arg camera_frame_id)"/>
    <arg name="io_method" value="$(arg io_method)"/>
  </include>

  <node pkg="sagittarius_openclaw_bridge"
        type="command_bridge.py"
        name="command_bridge"
        output="screen">
    <param name="robot_name" value="$(arg robot_name)"/>
    <param name="service_name" value="$(arg service_name)"/>
    <param name="image_topic" value="$(arg image_topic)"/>
    <param name="vision_config" value="$(arg vision_config)"/>
    <param name="find_timeout" value="$(arg find_timeout)"/>
    <param name="publish_debug_images" value="$(arg publish_debug_images)"/>
  </node>
</launch>
