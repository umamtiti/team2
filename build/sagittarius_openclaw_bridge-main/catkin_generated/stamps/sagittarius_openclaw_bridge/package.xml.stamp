<?xml version="1.0"?>
<package format="2">
  <name>sagittarius_openclaw_bridge</name>
  <version>0.0.1</version>
  <description>Bridge package that exposes Sagittarius arm skills as stable commands for OpenClaw.</description>

  <maintainer email="codex@openai.com">Codex</maintainer>
  <license>MIT</license>

  <buildtool_depend>catkin</buildtool_depend>

  <build_depend>actionlib</build_depend>
  <build_depend>cv_bridge</build_depend>
  <build_depend>message_generation</build_depend>
  <build_depend>rospy</build_depend>
  <build_depend>sensor_msgs</build_depend>
  <build_depend>sagittarius_object_color_detector</build_depend>

  <build_export_depend>actionlib</build_export_depend>
  <build_export_depend>cv_bridge</build_export_depend>
  <build_export_depend>rospy</build_export_depend>
  <build_export_depend>sensor_msgs</build_export_depend>
  <build_export_depend>sagittarius_object_color_detector</build_export_depend>

  <exec_depend>actionlib</exec_depend>
  <exec_depend>cv_bridge</exec_depend>
  <exec_depend>message_runtime</exec_depend>
  <exec_depend>python3-opencv</exec_depend>
  <exec_depend>python3-yaml</exec_depend>
  <exec_depend>rospy</exec_depend>
  <exec_depend>sensor_msgs</exec_depend>
  <exec_depend>sagittarius_moveit</exec_depend>
  <exec_depend>sagittarius_object_color_detector</exec_depend>

  <export/>
</package>
